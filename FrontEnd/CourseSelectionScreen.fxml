<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="CourseSelectionController"
        prefWidth="600" prefHeight="700"
        style="-fx-background-color: #1a1f2e;">

    <!-- ── Main content column ── -->
    <VBox spacing="0">

        <!-- Top Nav Bar -->
        <HBox
                alignment="CENTER_LEFT"
                spacing="14"
                style="-fx-background-color: #222736;
                   -fx-border-color: rgba(255,255,255,0.06);
                   -fx-border-width: 0 0 1 0;"
                prefHeight="60">
            <padding><Insets left="16" right="24"/></padding>

            <!-- Logo -->
            <StackPane
                    minWidth="36" minHeight="36"
                    maxWidth="36" maxHeight="36"
                    style="-fx-background-color: #2ecc71;
                       -fx-background-radius: 8;">
                <Label text="N"
                       style="-fx-text-fill: white;
                           -fx-font-size: 16px;
                           -fx-font-weight: bold;"/>
            </StackPane>

            <Label text="Nust Nest"
                   style="-fx-text-fill: #f0f0f0;
                       -fx-font-size: 16px;
                       -fx-font-weight: bold;"/>
            <Label text="SEECS Edition"
                   style="-fx-text-fill: #2ecc71;
                       -fx-font-size: 12px;
                       -fx-font-weight: 600;"/>

            <!-- Spacer — pushes buttons to the right -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Chat button -->
            <Button fx:id="chatButton"
                    text="💬  Chat"
                    onAction="#handleChat"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #2ecc71;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;
                           -fx-padding: 6 14 6 14;
                           -fx-background-radius: 8;
                           -fx-border-color: rgba(46,204,113,0.35);
                           -fx-border-radius: 8;
                           -fx-border-width: 1;"/>

            <!-- Profile button -->
            <Button fx:id="profileButton"
                    text="👤  Profile"
                    onAction="#handleProfile"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #aaaaaa;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;
                           -fx-padding: 6 14 6 14;
                           -fx-background-radius: 8;
                           -fx-border-color: rgba(255,255,255,0.12);
                           -fx-border-radius: 8;
                           -fx-border-width: 1;"/>

            <!-- Logout button -->
            <Button fx:id="logoutButton"
                    text="🚪  Logout"
                    onAction="#handleLogout"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #e74c3c;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;
                           -fx-padding: 6 14 6 14;
                           -fx-background-radius: 8;
                           -fx-border-color: rgba(231,76,60,0.35);
                           -fx-border-radius: 8;
                           -fx-border-width: 1;"/>
        </HBox>

        <!-- Page Title -->
        <VBox style="-fx-background-color: #1a1f2e;">
            <padding><Insets top="28" left="28" right="28" bottom="16"/></padding>
            <Label text="Select a Course"
                   style="-fx-text-fill: #f0f0f0;
                       -fx-font-size: 20px;
                       -fx-font-weight: bold;">
                <VBox.margin><Insets bottom="6"/></VBox.margin>
            </Label>
            <Label text="Click on a course to view or upload notes"
                   style="-fx-text-fill: #666666;
                       -fx-font-size: 13px;"/>
        </VBox>

        <!-- Scrollable Course Grid -->
        <ScrollPane
                fitToWidth="true"
                style="-fx-background: #1a1f2e;
                   -fx-background-color: #1a1f2e;
                   -fx-border-width: 0;"
                VBox.vgrow="ALWAYS">

            <FlowPane
                    fx:id="courseGrid"
                    hgap="16" vgap="16"
                    style="-fx-background-color: #1a1f2e;">
                <padding><Insets top="8" left="28" right="28" bottom="28"/></padding>

                <!-- OOP -->
                <VBox fx:id="card_oop"
                      prefWidth="160" prefHeight="140"
                      style="-fx-background-color: #222736;
                           -fx-background-radius: 14;
                           -fx-border-color: rgba(255,255,255,0.08);
                           -fx-border-radius: 14;
                           -fx-border-width: 1;
                           -fx-cursor: hand;">
                    <padding><Insets top="18" left="18" right="18" bottom="18"/></padding>
                    <Label text="OOP"
                           style="-fx-text-fill: #f0f0f0;
                               -fx-font-size: 15px;
                               -fx-font-weight: bold;">
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                    </Label>
                    <Label text="CS-212 Object Oriented Programming"
                           style="-fx-text-fill: #666666;
                               -fx-font-size: 11px;"
                           wrapText="true">
                        <VBox.margin><Insets bottom="16"/></VBox.margin>
                    </Label>
                    <Region VBox.vgrow="ALWAYS"/>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <StackPane minWidth="8" minHeight="8" maxWidth="8" maxHeight="8"
                                   style="-fx-background-color: #555555; -fx-background-radius: 4;"/>
                        <Label fx:id="count_oop" text="0 files"
                               style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                    </HBox>
                </VBox>

                <!-- Linear Algebra -->
                <VBox fx:id="card_la"
                      prefWidth="160" prefHeight="140"
                      style="-fx-background-color: #222736;
                           -fx-background-radius: 14;
                           -fx-border-color: rgba(255,255,255,0.08);
                           -fx-border-radius: 14;
                           -fx-border-width: 1;
                           -fx-cursor: hand;">
                    <padding><Insets top="18" left="18" right="18" bottom="18"/></padding>
                    <Label text="Linear Algebra"
                           style="-fx-text-fill: #f0f0f0;
                               -fx-font-size: 15px;
                               -fx-font-weight: bold;">
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                    </Label>
                    <Label text="MATH-121 Matrices, Vectors and more"
                           style="-fx-text-fill: #666666;
                               -fx-font-size: 11px;"
                           wrapText="true">
                        <VBox.margin><Insets bottom="16"/></VBox.margin>
                    </Label>
                    <Region VBox.vgrow="ALWAYS"/>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <StackPane minWidth="8" minHeight="8" maxWidth="8" maxHeight="8"
                                   style="-fx-background-color: #555555; -fx-background-radius: 4;"/>
                        <Label fx:id="count_la" text="0 files"
                               style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                    </HBox>
                </VBox>

                <!-- Discrete Maths -->
                <VBox fx:id="card_dm"
                      prefWidth="160" prefHeight="140"
                      style="-fx-background-color: #222736;
                           -fx-background-radius: 14;
                           -fx-border-color: rgba(255,255,255,0.08);
                           -fx-border-radius: 14;
                           -fx-border-width: 1;
                           -fx-cursor: hand;">
                    <padding><Insets top="18" left="18" right="18" bottom="18"/></padding>
                    <Label text="Discrete Maths"
                           style="-fx-text-fill: #f0f0f0;
                               -fx-font-size: 15px;
                               -fx-font-weight: bold;">
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                    </Label>
                    <Label text="MATH-161 Logic, Sets and Graph Theory"
                           style="-fx-text-fill: #666666;
                               -fx-font-size: 11px;"
                           wrapText="true">
                        <VBox.margin><Insets bottom="16"/></VBox.margin>
                    </Label>
                    <Region VBox.vgrow="ALWAYS"/>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <StackPane minWidth="8" minHeight="8" maxWidth="8" maxHeight="8"
                                   style="-fx-background-color: #555555; -fx-background-radius: 4;"/>
                        <Label fx:id="count_dm" text="0 files"
                               style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                    </HBox>
                </VBox>

                <!-- Functional English -->
                <VBox fx:id="card_hu"
                      prefWidth="160" prefHeight="140"
                      style="-fx-background-color: #222736;
                           -fx-background-radius: 14;
                           -fx-border-color: rgba(255,255,255,0.08);
                           -fx-border-radius: 14;
                           -fx-border-width: 1;
                           -fx-cursor: hand;">
                    <padding><Insets top="18" left="18" right="18" bottom="18"/></padding>
                    <Label text="Functional English"
                           style="-fx-text-fill: #f0f0f0;
                               -fx-font-size: 15px;
                               -fx-font-weight: bold;">
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                    </Label>
                    <Label text="HU-114 English Skills"
                           style="-fx-text-fill: #666666;
                               -fx-font-size: 11px;"
                           wrapText="true">
                        <VBox.margin><Insets bottom="16"/></VBox.margin>
                    </Label>
                    <Region VBox.vgrow="ALWAYS"/>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <StackPane minWidth="8" minHeight="8" maxWidth="8" maxHeight="8"
                                   style="-fx-background-color: #555555; -fx-background-radius: 4;"/>
                        <Label fx:id="count_hu" text="0 files"
                               style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                    </HBox>
                </VBox>

                <!-- Digital Logic Design -->
                <VBox fx:id="card_dld"
                      prefWidth="160" prefHeight="140"
                      style="-fx-background-color: #222736;
                           -fx-background-radius: 14;
                           -fx-border-color: rgba(255,255,255,0.08);
                           -fx-border-radius: 14;
                           -fx-border-width: 1;
                           -fx-cursor: hand;">
                    <padding><Insets top="18" left="18" right="18" bottom="18"/></padding>
                    <Label text="Comp. Architecture &amp; Logic"
                           style="-fx-text-fill: #f0f0f0;
                               -fx-font-size: 15px;
                               -fx-font-weight: bold;">
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                    </Label>
                    <Label text="EE-122 Architecture &amp; Logic"
                           style="-fx-text-fill: #666666;
                               -fx-font-size: 11px;"
                           wrapText="true">
                        <VBox.margin><Insets bottom="16"/></VBox.margin>
                    </Label>
                    <Region VBox.vgrow="ALWAYS"/>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <StackPane minWidth="8" minHeight="8" maxWidth="8" maxHeight="8"
                                   style="-fx-background-color: #555555; -fx-background-radius: 4;"/>
                        <Label fx:id="count_dld" text="0 files"
                               style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                    </HBox>
                </VBox>

                <!-- Understanding of Quran -->
                <VBox fx:id="card_uoq"
                      prefWidth="160" prefHeight="140"
                      style="-fx-background-color: #222736;
                           -fx-background-radius: 14;
                           -fx-border-color: rgba(255,255,255,0.08);
                           -fx-border-radius: 14;
                           -fx-border-width: 1;
                           -fx-cursor: hand;">
                    <padding><Insets top="18" left="18" right="18" bottom="18"/></padding>
                    <Label text="Understanding of Quran"
                           style="-fx-text-fill: #f0f0f0;
                               -fx-font-size: 15px;
                               -fx-font-weight: bold;">
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                    </Label>
                    <Label text="HU-132 Quranic Studies"
                           style="-fx-text-fill: #666666;
                               -fx-font-size: 11px;"
                           wrapText="true">
                        <VBox.margin><Insets bottom="16"/></VBox.margin>
                    </Label>
                    <Region VBox.vgrow="ALWAYS"/>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <StackPane minWidth="8" minHeight="8" maxWidth="8" maxHeight="8"
                                   style="-fx-background-color: #555555; -fx-background-radius: 4;"/>
                        <Label fx:id="count_uoq" text="0 files"
                               style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                    </HBox>
                </VBox>

            </FlowPane>
        </ScrollPane>
    </VBox>



</StackPane>

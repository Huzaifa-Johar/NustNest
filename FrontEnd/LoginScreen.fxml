<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="LoginController"
        prefWidth="500" prefHeight="650"
        style="-fx-background-color: #1a1f2e;">

    <!-- Centered Card -->
    <VBox
            alignment="CENTER"
            maxWidth="360" maxHeight="560"
            style="-fx-background-color: #222736;
               -fx-background-radius: 16;
               -fx-border-color: rgba(255,255,255,0.08);
               -fx-border-radius: 16;
               -fx-border-width: 1;">
        <padding><Insets top="40" right="32" bottom="40" left="32"/></padding>

        <!-- Logo Row -->
        <HBox alignment="CENTER_LEFT" spacing="14">
            <VBox.margin><Insets bottom="24"/></VBox.margin>
            <StackPane
                    minWidth="52" minHeight="52"
                    maxWidth="52" maxHeight="52"
                    style="-fx-background-color: #2ecc71;
                       -fx-background-radius: 12;">
                <Label text="N"
                       style="-fx-text-fill: white;
                           -fx-font-size: 22px;
                           -fx-font-weight: bold;"/>
            </StackPane>
            <VBox spacing="2">
                <Label text="Nust Nest"
                       style="-fx-text-fill: #f0f0f0;
                           -fx-font-size: 20px;
                           -fx-font-weight: bold;"/>
                <Label text="SEECS Edition"
                       style="-fx-text-fill: #2ecc71;
                           -fx-font-size: 13px;
                           -fx-font-weight: 600;"/>
            </VBox>
        </HBox>

        <!-- Divider -->
        <Region prefHeight="1" maxWidth="Infinity"
                style="-fx-background-color: rgba(255,255,255,0.08);">
            <VBox.margin><Insets bottom="28"/></VBox.margin>
        </Region>

        <!-- Email Label -->
        <Label text="Email Address"
               style="-fx-text-fill: #aaaaaa;
                   -fx-font-size: 13px;
                   -fx-font-weight: 600;">
            <VBox.margin><Insets bottom="8"/></VBox.margin>
        </Label>

        <!-- Email Input -->
        <TextField
                fx:id="emailField"
                promptText="yourname@seecs.edu.pk"
                maxWidth="Infinity" prefHeight="46"
                onAction="#handleContinue"
                style="-fx-background-color: #2a2f40;
                   -fx-text-fill: #f0f0f0;
                   -fx-prompt-text-fill: #555555;
                   -fx-font-size: 13px;
                   -fx-background-radius: 10;
                   -fx-border-color: rgba(255,255,255,0.12);
                   -fx-border-radius: 10;
                   -fx-border-width: 1;
                   -fx-padding: 0 14 0 14;">
            <VBox.margin><Insets bottom="10"/></VBox.margin>
        </TextField>

        <!-- Password Label -->
        <Label text="Password"
               style="-fx-text-fill: #aaaaaa;
                   -fx-font-size: 13px;
                   -fx-font-weight: 600;">
            <VBox.margin><Insets bottom="8"/></VBox.margin>
        </Label>

        <!-- Password Input -->
        <PasswordField
                fx:id="passwordField"
                promptText="Enter your password"
                maxWidth="Infinity" prefHeight="46"
                onAction="#handleContinue"
                style="-fx-background-color: #2a2f40;
                   -fx-text-fill: #f0f0f0;
                   -fx-prompt-text-fill: #555555;
                   -fx-font-size: 13px;
                   -fx-background-radius: 10;
                   -fx-border-color: rgba(255,255,255,0.12);
                   -fx-border-radius: 10;
                   -fx-border-width: 1;
                   -fx-padding: 0 14 0 14;">
            <VBox.margin><Insets bottom="10"/></VBox.margin>
        </PasswordField>

        <!-- Error Label -->
        <Label fx:id="errorLabel" text=""
               maxWidth="Infinity" minHeight="18"
               style="-fx-text-fill: #e74c3c;
                   -fx-font-size: 12px;">
            <VBox.margin><Insets bottom="14"/></VBox.margin>
        </Label>

        <!-- Login Button -->
        <Button fx:id="continueButton"
                text="Login"
                maxWidth="Infinity" prefHeight="46"
                onAction="#handleContinue"
                style="-fx-background-color: #2ecc71;
                   -fx-text-fill: #0d1117;
                   -fx-font-size: 14px;
                   -fx-font-weight: bold;
                   -fx-background-radius: 10;
                   -fx-border-width: 0;
                   -fx-cursor: hand;">
            <VBox.margin><Insets bottom="10"/></VBox.margin>
        </Button>

        <Button text="Create account"
                maxWidth="Infinity" prefHeight="42"
                onAction="#handleGoToSignUp"
                style="-fx-background-color: transparent;
                   -fx-text-fill: #2ecc71;
                   -fx-font-size: 13px;
                   -fx-font-weight: 600;
                   -fx-border-color: rgba(46,204,113,0.35);
                   -fx-border-radius: 10;
                   -fx-border-width: 1;
                   -fx-background-radius: 10;
                   -fx-cursor: hand;">
            <VBox.margin><Insets bottom="20"/></VBox.margin>
        </Button>

        <!-- Notice Box -->
        <VBox
                style="-fx-background-color: rgba(46,204,113,0.08);
                   -fx-background-radius: 10;
                   -fx-border-color: rgba(46,204,113,0.3);
                   -fx-border-radius: 10;
                   -fx-border-width: 1;">
            <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
            <Label text="Only @seecs.edu.pk accounts are accepted"
                   style="-fx-text-fill: #2ecc71;
                       -fx-font-size: 13px;"/>
        </VBox>

    </VBox>

    <!-- Footer -->
    <VBox alignment="BOTTOM_CENTER" mouseTransparent="true">
        <padding><Insets bottom="20"/></padding>
        <Label text="School of Electrical Engineering and Computer Science"
               style="-fx-text-fill: #444444; -fx-font-size: 11px;"/>
        <Label text="National University of Science and Technology"
               style="-fx-text-fill: #444444; -fx-font-size: 11px;"/>
    </VBox>

</StackPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<StackPane
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="ProfileSetupController"
        prefWidth="500" prefHeight="700"
        style="-fx-background-color: #1a1f2e;">

    <!-- Centered Card -->
    <VBox
            alignment="TOP_CENTER"
            maxWidth="380"
            style="-fx-background-color: #222736;
               -fx-background-radius: 16;
               -fx-border-color: rgba(255,255,255,0.08);
               -fx-border-radius: 16;
               -fx-border-width: 1;">
        <padding><Insets top="36" right="32" bottom="36" left="32"/></padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="14">
            <VBox.margin><Insets bottom="6"/></VBox.margin>
            <StackPane
                    minWidth="42" minHeight="42"
                    maxWidth="42" maxHeight="42"
                    style="-fx-background-color: #2ecc71;
                       -fx-background-radius: 10;">
                <Label text="N"
                       style="-fx-text-fill: white;
                           -fx-font-size: 18px;
                           -fx-font-weight: bold;"/>
            </StackPane>
            <VBox spacing="1">
                <Label text="Nust Nest"
                       style="-fx-text-fill: #f0f0f0;
                           -fx-font-size: 17px;
                           -fx-font-weight: bold;"/>
                <Label text="SEECS Edition"
                       style="-fx-text-fill: #2ecc71;
                           -fx-font-size: 12px;
                           -fx-font-weight: 600;"/>
            </VBox>
        </HBox>

        <!-- Divider -->
        <Region prefHeight="1" maxWidth="Infinity"
                style="-fx-background-color: rgba(255,255,255,0.08);">
            <VBox.margin><Insets top="16" bottom="24"/></VBox.margin>
        </Region>

        <!-- Title -->
        <Label text="Set Up Your Profile"
               style="-fx-text-fill: #f0f0f0;
                   -fx-font-size: 18px;
                   -fx-font-weight: bold;">
            <VBox.margin><Insets bottom="4"/></VBox.margin>
        </Label>
        <Label text="This is how others will see you on NustNest"
               style="-fx-text-fill: #666666;
                   -fx-font-size: 12px;">
            <VBox.margin><Insets bottom="28"/></VBox.margin>
        </Label>

        <!-- Profile Picture -->
        <VBox alignment="CENTER">
            <VBox.margin><Insets bottom="24"/></VBox.margin>

            <!-- PFP Circle -->
            <StackPane
                    fx:id="pfpPane"
                    maxWidth="90" maxHeight="90"
                    minWidth="90" minHeight="90"
                    style="-fx-background-color: #2a2f40;
                       -fx-background-radius: 45;
                       -fx-border-color: rgba(46,204,113,0.4);
                       -fx-border-radius: 45;
                       -fx-border-width: 2;
                       -fx-cursor: hand;">
                <VBox.margin><Insets bottom="10"/></VBox.margin>
                <Label fx:id="pfpInitials" text="?"
                       style="-fx-text-fill: #555555;
                           -fx-font-size: 30px;
                           -fx-font-weight: bold;"/>
            </StackPane>

            <!-- Upload button -->
            <Button fx:id="uploadPfpButton"
                    text="Upload Photo"
                    onAction="#handleUploadPfp"
                    style="-fx-background-color: transparent;
                       -fx-text-fill: #2ecc71;
                       -fx-font-size: 12px;
                       -fx-font-weight: 600;
                       -fx-border-color: rgba(46,204,113,0.4);
                       -fx-border-radius: 8;
                       -fx-border-width: 1;
                       -fx-background-radius: 8;
                       -fx-cursor: hand;
                       -fx-padding: 6 16 6 16;"/>
        </VBox>

        <!-- Full Name -->
        <Label text="Full Name"
               style="-fx-text-fill: #aaaaaa;
                   -fx-font-size: 13px;
                   -fx-font-weight: 600;">
            <VBox.margin><Insets bottom="8"/></VBox.margin>
        </Label>
        <TextField fx:id="nameField"
                   promptText="e.g. Muhammad Huzaifa"
                   maxWidth="Infinity" prefHeight="44"
                   style="-fx-background-color: #2a2f40;
                   -fx-text-fill: #f0f0f0;
                   -fx-prompt-text-fill: #555555;
                   -fx-font-size: 13px;
                   -fx-background-radius: 10;
                   -fx-border-color: rgba(255,255,255,0.12);
                   -fx-border-radius: 10;
                   -fx-border-width: 1;
                   -fx-padding: 0 14 0 14;">
            <VBox.margin><Insets bottom="16"/></VBox.margin>
        </TextField>

        <!-- Bio -->
        <Label text="Bio"
               style="-fx-text-fill: #aaaaaa;
                   -fx-font-size: 13px;
                   -fx-font-weight: 600;">
            <VBox.margin><Insets bottom="8"/></VBox.margin>
        </Label>
        <TextArea fx:id="bioField"
                  promptText="Tell others a little about yourself..."
                  maxWidth="Infinity" prefHeight="90"
                  wrapText="true"
                  style="-fx-control-inner-background: #2a2f40;
           -fx-text-fill: #f0f0f0;
           -fx-prompt-text-fill: #555555;
           -fx-font-size: 13px;
           -fx-background-radius: 10;
           -fx-border-color: rgba(255,255,255,0.12);
           -fx-border-radius: 10;
           -fx-border-width: 1;">
            <VBox.margin><Insets bottom="8"/></VBox.margin>
        </TextArea>

        <!-- Bio character count -->
        <Label fx:id="bioCharCount" text="0 / 150"
               maxWidth="Infinity"
               style="-fx-text-fill: #555555;
                   -fx-font-size: 11px;
                   -fx-alignment: center-right;">
            <VBox.margin><Insets bottom="16"/></VBox.margin>
        </Label>

        <!-- Error Label -->
        <Label fx:id="errorLabel" text=""
               maxWidth="Infinity" minHeight="18"
               style="-fx-text-fill: #e74c3c;
                   -fx-font-size: 12px;">
            <VBox.margin><Insets bottom="10"/></VBox.margin>
        </Label>

        <!-- Save Button -->
        <Button fx:id="saveButton"
                text="Save and Continue →"
                maxWidth="Infinity" prefHeight="46"
                onAction="#handleSave"
                style="-fx-background-color: #2ecc71;
                   -fx-text-fill: #0d1117;
                   -fx-font-size: 14px;
                   -fx-font-weight: bold;
                   -fx-background-radius: 10;
                   -fx-border-width: 0;
                   -fx-cursor: hand;">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </Button>

        <!-- Skip for now -->
        <Button text="Skip for now"
                maxWidth="Infinity"
                onAction="#handleSkip"
                style="-fx-background-color: transparent;
                   -fx-text-fill: #555555;
                   -fx-font-size: 12px;
                   -fx-border-width: 0;
                   -fx-cursor: hand;
                   -fx-padding: 4 0 0 0;"/>

    </VBox>

    <!-- Footer -->
    <VBox alignment="BOTTOM_CENTER" mouseTransparent="true">
        <padding><Insets bottom="20"/></padding>
        <Label text="School of Electrical Engineering and Computer Science"
               style="-fx-text-fill: #444444; -fx-font-size: 11px;"/>
        <Label text="National University of Science and Technology"
               style="-fx-text-fill: #444444; -fx-font-size: 11px;"/>
    </VBox>

</StackPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<StackPane
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="SuccessController"
        prefWidth="500" prefHeight="650"
        style="-fx-background-color: #1a1f2e;">

    <!-- Outer centered card -->
    <VBox
            alignment="CENTER"
            maxWidth="360" maxHeight="380"
            style="-fx-background-color: #222736;
               -fx-background-radius: 16;
               -fx-border-color: rgba(255,255,255,0.08);
               -fx-border-radius: 16;
               -fx-border-width: 1;">
        <padding><Insets top="48" right="32" bottom="48" left="32"/></padding>

        <!-- Green circle with checkmark -->
        <StackPane
                maxWidth="64" maxHeight="64"
                minWidth="64" minHeight="64"
                style="-fx-background-color: rgba(46,204,113,0.12);
                   -fx-background-radius: 32;"
                StackPane.alignment="CENTER">
            <VBox.margin><Insets bottom="20"/></VBox.margin>
            <SVGPath
                    content="M6 12 L10.5 16.5 L18 8"
                    stroke="#2ecc71"
                    strokeWidth="2.2"
                    fill="transparent"
                    scaleX="1.8" scaleY="1.8"/>
        </StackPane>

        <!-- Title -->
        <Label text="You're in!"
               style="-fx-text-fill: #f0f0f0;
                   -fx-font-size: 22px;
                   -fx-font-weight: bold;"
               alignment="CENTER" maxWidth="Infinity">
            <VBox.margin><Insets bottom="10"/></VBox.margin>
        </Label>

        <!-- Subtitle -->
        <Label text="Verified successfully."
               style="-fx-text-fill: #888888;
                   -fx-font-size: 14px;"
               alignment="CENTER" maxWidth="Infinity">
            <VBox.margin><Insets bottom="4"/></VBox.margin>
        </Label>
        <Label text="Welcome to NustNest."
               style="-fx-text-fill: #888888;
                   -fx-font-size: 14px;"
               alignment="CENTER" maxWidth="Infinity">
            <VBox.margin><Insets bottom="32"/></VBox.margin>
        </Label>

        <!-- Continue Button -->
        <Button fx:id="continueButton"
                text="Continue to App →"
                maxWidth="Infinity" prefHeight="44"
                onAction="#handleContinue"
                style="-fx-background-color: #2ecc71;
               -fx-text-fill: #0d1117;
               -fx-font-size: 14px;
               -fx-font-weight: bold;
               -fx-background-radius: 10;
               -fx-cursor: hand;"/>

    </VBox>

    <!-- Footer -->
    <VBox alignment="BOTTOM_CENTER" mouseTransparent="true">
        <padding><Insets bottom="20"/></padding>
        <Label text="School of Electrical Engineering and Computer Science"
               style="-fx-text-fill: #444444; -fx-font-size: 11px;"/>
        <Label text="National University of Science and Technology"
               style="-fx-text-fill: #444444; -fx-font-size: 11px;"/>
    </VBox>

</StackPane>

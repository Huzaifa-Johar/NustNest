<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="UserSearchController"
        prefWidth="600" prefHeight="700"
        style="-fx-background-color: #1a1f2e;">

    <VBox spacing="0">

        <!-- Top Nav Bar -->
        <HBox
                alignment="CENTER_LEFT"
                spacing="14"
                style="-fx-background-color: #222736;
                       -fx-border-color: rgba(255,255,255,0.06);
                       -fx-border-width: 0 0 1 0;"
                prefHeight="60">
            <padding><Insets left="16" right="24"/></padding>

            <!-- Logo -->
            <StackPane
                    minWidth="36" minHeight="36"
                    maxWidth="36" maxHeight="36"
                    style="-fx-background-color: #2ecc71;
                           -fx-background-radius: 8;">
                <Label text="N"
                       style="-fx-text-fill: white;
                               -fx-font-size: 16px;
                               -fx-font-weight: bold;"/>
            </StackPane>

            <Label text="Nust Nest"
                   style="-fx-text-fill: #f0f0f0;
                           -fx-font-size: 16px;
                           -fx-font-weight: bold;"/>
            <Label text="SEECS Edition"
                   style="-fx-text-fill: #2ecc71;
                           -fx-font-size: 12px;
                           -fx-font-weight: 600;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Back button -->
            <Button fx:id="backButton"
                    text="← Back"
                    onAction="#handleBack"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #aaaaaa;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;
                           -fx-padding: 6 14 6 14;
                           -fx-background-radius: 8;
                           -fx-border-color: rgba(255,255,255,0.12);
                           -fx-border-radius: 8;
                           -fx-border-width: 1;"/>
        </HBox>

        <!-- Page Title -->
        <VBox style="-fx-background-color: #1a1f2e;">
            <padding><Insets top="28" left="28" right="28" bottom="20"/></padding>
            <Label text="💬  Start a Chat"
                   style="-fx-text-fill: #f0f0f0;
                           -fx-font-size: 20px;
                           -fx-font-weight: bold;">
                <VBox.margin><Insets bottom="6"/></VBox.margin>
            </Label>
            <Label text="Search for a student or teacher to message"
                   style="-fx-text-fill: #666666;
                           -fx-font-size: 13px;"/>
        </VBox>

        <!-- Search Field -->
        <VBox style="-fx-background-color: #1a1f2e;">
            <padding><Insets left="28" right="28" bottom="16"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField"
                           promptText="Search by name..."
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-color: #222736;
                                  -fx-text-fill: #f0f0f0;
                                  -fx-prompt-text-fill: #555555;
                                  -fx-font-size: 14px;
                                  -fx-padding: 10 16 10 16;
                                  -fx-background-radius: 10;
                                  -fx-border-color: rgba(255,255,255,0.10);
                                  -fx-border-radius: 10;
                                  -fx-border-width: 1;"/>
                <Button fx:id="searchButton"
                        text="Search"
                        onAction="#handleSearch"
                        style="-fx-background-color: #2ecc71;
                               -fx-text-fill: #1a1f2e;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-cursor: hand;
                               -fx-padding: 10 20 10 20;
                               -fx-background-radius: 10;
                               -fx-border-width: 0;"/>
            </HBox>
        </VBox>

        <!-- Status label -->
        <Label fx:id="statusLabel"
               text=""
               style="-fx-text-fill: #555555; -fx-font-size: 13px;">
            <VBox.margin><Insets left="28" bottom="8"/></VBox.margin>
        </Label>

        <!-- Results List -->
        <ListView fx:id="resultsList"
                  VBox.vgrow="ALWAYS"
                  style="-fx-background-color: #1a1f2e;
                         -fx-border-width: 0;
                         -fx-padding: 0 28 28 28;"/>

    </VBox>

</StackPane>

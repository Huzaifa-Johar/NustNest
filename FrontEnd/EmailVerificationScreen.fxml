<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="EmailVerificationController"
           style="-fx-background-color: #0d1117;">

    <VBox alignment="CENTER" spacing="0"
          style="-fx-background-color: #161b27; -fx-background-radius: 18; -fx-padding: 48 40 40 40;"
          maxWidth="420" maxHeight="480">

        <!-- Email icon circle -->
        <StackPane alignment="CENTER">
            <Circle radius="44" fill="#1e2436" stroke="rgba(46,204,113,0.3)" strokeWidth="1.5"/>
            <Label text="✉" style="-fx-font-size: 38px;"/>
        </StackPane>

        <VBox spacing="0" alignment="CENTER" style="-fx-padding: 28 0 0 0;">
            <Label text="Check Your Email"
                   style="-fx-text-fill: #f0f0f0; -fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Label text="A verification link has been sent to"
                   style="-fx-text-fill: #888888; -fx-font-size: 13px; -fx-padding: 10 0 4 0;"/>
            <Label fx:id="emailLabel"
                   text="your@email.com"
                   style="-fx-text-fill: #2ecc71; -fx-font-size: 13px; -fx-font-weight: bold;"/>
        </VBox>

        <!-- Animated waiting indicator -->
        <VBox alignment="CENTER" spacing="8" style="-fx-padding: 32 0 8 0;">
            <Label fx:id="statusLabel"
                   text="Waiting for verification..."
                   style="-fx-text-fill: #888888; -fx-font-size: 13px;"/>
            <ProgressIndicator fx:id="spinner"
                               prefWidth="28" prefHeight="28"
                               style="-fx-progress-color: #2ecc71;"/>
        </VBox>

        <!-- Error label -->
        <Label fx:id="errorLabel" text=""
               style="-fx-text-fill: #e74c3c; -fx-font-size: 12px; -fx-padding: 6 0 0 0;"
               wrapText="true" alignment="CENTER"/>

        <!-- Resend + Back buttons -->
        <VBox spacing="10" alignment="CENTER" style="-fx-padding: 24 0 0 0;">
            <Button fx:id="resendButton" text="Resend Email"
                    prefWidth="220"
                    style="-fx-background-color: #2ecc71; -fx-text-fill: #0d1117; -fx-font-size: 13px;
                           -fx-font-weight: bold; -fx-background-radius: 10; -fx-border-width: 0;
                           -fx-cursor: hand; -fx-padding: 10 0 10 0;"
                    onAction="#handleResend"/>
            <Button fx:id="backButton" text="← Back to Login"
                    prefWidth="220"
                    style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-font-size: 12px;
                           -fx-background-radius: 10; -fx-border-width: 0; -fx-cursor: hand;"
                    onAction="#handleBack"/>
        </VBox>

    </VBox>
</StackPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="NotesController"
        prefWidth="600" prefHeight="700"
        style="-fx-background-color: #1a1f2e;">

    <VBox spacing="0">

        <!-- Top Nav Bar -->
        <HBox
                alignment="CENTER_LEFT"
                spacing="14"
                style="-fx-background-color: #222736;
                   -fx-border-color: rgba(255,255,255,0.06);
                   -fx-border-width: 0 0 1 0;"
                prefHeight="60">
            <padding><Insets left="24" right="24"/></padding>

            <StackPane
                    minWidth="36" minHeight="36"
                    maxWidth="36" maxHeight="36"
                    style="-fx-background-color: #2ecc71;
                       -fx-background-radius: 8;">
                <Label text="N"
                       style="-fx-text-fill: white;
                           -fx-font-size: 16px;
                           -fx-font-weight: bold;"/>
            </StackPane>
            <Label text="Nust Nest"
                   style="-fx-text-fill: #f0f0f0;
                       -fx-font-size: 16px;
                       -fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button fx:id="backButton"
                    text="← Courses"
                    onAction="#handleBack"
                    style="-fx-background-color: transparent;
                       -fx-text-fill: #888888;
                       -fx-font-size: 12px;
                       -fx-border-color: rgba(255,255,255,0.12);
                       -fx-border-radius: 8;
                       -fx-border-width: 1;
                       -fx-background-radius: 8;
                       -fx-cursor: hand;
                       -fx-padding: 6 14 6 14;"/>
        </HBox>

        <!-- Course Header -->
        <VBox style="-fx-background-color: #1a1f2e;">
            <padding><Insets top="28" left="28" right="28" bottom="20"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="16">
                <StackPane
                        minWidth="48" minHeight="48"
                        maxWidth="48" maxHeight="48"
                        style="-fx-background-color: rgba(46,204,113,0.12);
                           -fx-background-radius: 12;
                           -fx-border-color: rgba(46,204,113,0.25);
                           -fx-border-radius: 12;
                           -fx-border-width: 1;">
                    <Label fx:id="courseIcon" text="?"
                           style="-fx-text-fill: #2ecc71;
                               -fx-font-size: 20px;
                               -fx-font-weight: bold;"/>
                </StackPane>
                <VBox spacing="4">
                    <Label fx:id="courseTitleLabel" text="Course Name"
                           style="-fx-text-fill: #f0f0f0;
                               -fx-font-size: 20px;
                               -fx-font-weight: bold;"/>
                    <Label fx:id="fileCountLabel" text="0 files uploaded"
                           style="-fx-text-fill: #666666;
                               -fx-font-size: 13px;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="uploadButton"
                        text="+ Upload Notes"
                        onAction="#handleUpload"
                        style="-fx-background-color: #2ecc71;
                           -fx-text-fill: #0d1117;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 10;
                           -fx-border-width: 0;
                           -fx-cursor: hand;
                           -fx-padding: 10 18 10 18;"/>
            </HBox>
        </VBox>

        <!-- Divider -->
        <Region prefHeight="1" style="-fx-background-color: rgba(255,255,255,0.06);"/>

        <!-- Sort Bar (right-aligned button) -->
        <HBox alignment="CENTER_RIGHT" spacing="10"
              style="-fx-background-color: #1a1f2e;"
              prefHeight="50">
            <padding><Insets left="28" right="28"/></padding>
            <Button fx:id="sortButton"
                    text="⭐  Highest Rated  ▾"
                    onAction="#handleSortButton"
                    style="-fx-background-color: #222736;
                       -fx-text-fill: #f0f0f0;
                       -fx-font-size: 12px;
                       -fx-border-color: rgba(255,255,255,0.10);
                       -fx-border-radius: 8;
                       -fx-background-radius: 8;
                       -fx-border-width: 1;
                       -fx-cursor: hand;
                       -fx-padding: 8 14 8 14;"/>
        </HBox>

        <!-- Divider -->
        <Region prefHeight="1" style="-fx-background-color: rgba(255,255,255,0.04);"/>

        <!-- Notes List -->
        <ScrollPane
                fitToWidth="true"
                style="-fx-background: #1a1f2e;
                   -fx-background-color: #1a1f2e;
                   -fx-border-width: 0;"
                VBox.vgrow="ALWAYS">

            <VBox fx:id="notesContainer" spacing="10">
                <padding><Insets top="20" left="28" right="28" bottom="28"/></padding>

                <VBox fx:id="emptyState" alignment="CENTER" prefHeight="300">
                    <StackPane
                            maxWidth="64" maxHeight="64"
                            minWidth="64" minHeight="64"
                            style="-fx-background-color: rgba(255,255,255,0.04);
                               -fx-background-radius: 32;"
                            StackPane.alignment="CENTER">
                        <VBox.margin><Insets bottom="16"/></VBox.margin>
                        <Label text="📂" style="-fx-font-size: 28px;"/>
                    </StackPane>
                    <Label text="No notes uploaded yet"
                           style="-fx-text-fill: #555555;
                               -fx-font-size: 15px;
                               -fx-font-weight: bold;">
                        <VBox.margin><Insets bottom="6"/></VBox.margin>
                    </Label>
                    <Label text="Click Upload Notes to add files for this course"
                           style="-fx-text-fill: #444444; -fx-font-size: 12px;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>

</StackPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="ChatScreenController"
        prefWidth="600" prefHeight="700"
        style="-fx-background-color: #1a1f2e;">

    <VBox spacing="0">

        <!-- Top Nav Bar -->
        <HBox
                alignment="CENTER_LEFT"
                spacing="14"
                style="-fx-background-color: #222736;
                       -fx-border-color: rgba(255,255,255,0.06);
                       -fx-border-width: 0 0 1 0;"
                prefHeight="60">
            <padding><Insets left="16" right="24"/></padding>

            <!-- Logo -->
            <StackPane
                    minWidth="36" minHeight="36"
                    maxWidth="36" maxHeight="36"
                    style="-fx-background-color: #2ecc71;
                           -fx-background-radius: 8;">
                <Label text="N"
                       style="-fx-text-fill: white;
                               -fx-font-size: 16px;
                               -fx-font-weight: bold;"/>
            </StackPane>

            <Label text="Nust Nest"
                   style="-fx-text-fill: #f0f0f0;
                           -fx-font-size: 16px;
                           -fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Back button -->
            <Button fx:id="backButton"
                    text="← Back"
                    onAction="#handleBack"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #aaaaaa;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;
                           -fx-padding: 6 14 6 14;
                           -fx-background-radius: 8;
                           -fx-border-color: rgba(255,255,255,0.12);
                           -fx-border-radius: 8;
                           -fx-border-width: 1;"/>
        </HBox>

        <!-- Chat Header: name + online indicator -->
        <HBox
                alignment="CENTER_LEFT"
                spacing="12"
                style="-fx-background-color: #222736;
                       -fx-border-color: rgba(255,255,255,0.04);
                       -fx-border-width: 0 0 1 0;"
                prefHeight="64">
            <padding><Insets left="24" right="24"/></padding>

            <!-- Avatar circle -->
            <StackPane
                    minWidth="40" minHeight="40"
                    maxWidth="40" maxHeight="40"
                    style="-fx-background-color: #2a3040;
                           -fx-background-radius: 20;">
                <Label fx:id="avatarLabel"
                       text="?"
                       style="-fx-text-fill: #2ecc71;
                               -fx-font-size: 16px;
                               -fx-font-weight: bold;"/>
            </StackPane>

            <VBox spacing="2">
                <Label fx:id="chatPartnerName"
                       text="Select a user"
                       style="-fx-text-fill: #f0f0f0;
                               -fx-font-size: 15px;
                               -fx-font-weight: bold;"/>
                <!-- Online indicator -->
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <StackPane fx:id="onlineDot"
                               minWidth="8" minHeight="8"
                               maxWidth="8" maxHeight="8"
                               style="-fx-background-color: #555555;
                                      -fx-background-radius: 4;"/>
                    <Label fx:id="onlineStatusLabel"
                           text="offline"
                           style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                </HBox>
            </VBox>
        </HBox>

        <!-- Messages Area -->
        <ScrollPane
                fx:id="messagesScrollPane"
                fitToWidth="true"
                VBox.vgrow="ALWAYS"
                style="-fx-background: #1a1f2e;
                       -fx-background-color: #1a1f2e;
                       -fx-border-width: 0;">

            <VBox fx:id="messagesContainer"
                  spacing="10"
                  style="-fx-background-color: #1a1f2e;">
                <padding><Insets top="16" left="20" right="20" bottom="16"/></padding>

                <!-- Messages injected here by controller -->

            </VBox>
        </ScrollPane>

        <!-- Input Bar -->
        <HBox
                alignment="CENTER"
                spacing="10"
                style="-fx-background-color: #222736;
                       -fx-border-color: rgba(255,255,255,0.06);
                       -fx-border-width: 1 0 0 0;"
                prefHeight="68">
            <padding><Insets left="20" right="20" top="12" bottom="12"/></padding>

            <TextField fx:id="messageInput"
                       promptText="Type a message..."
                       HBox.hgrow="ALWAYS"
                       style="-fx-background-color: #2a2f40;
                              -fx-text-fill: #f0f0f0;
                              -fx-prompt-text-fill: #555555;
                              -fx-font-size: 14px;
                              -fx-padding: 10 16 10 16;
                              -fx-background-radius: 22;
                              -fx-border-color: rgba(255,255,255,0.08);
                              -fx-border-radius: 22;
                              -fx-border-width: 1;"/>

            <Button fx:id="sendButton"
                    text="➤"
                    onAction="#handleSend"
                    style="-fx-background-color: #2ecc71;
                           -fx-text-fill: #1a1f2e;
                           -fx-font-size: 16px;
                           -fx-font-weight: bold;
                           -fx-cursor: hand;
                           -fx-min-width: 44;
                           -fx-min-height: 44;
                           -fx-max-width: 44;
                           -fx-max-height: 44;
                           -fx-background-radius: 22;
                           -fx-border-width: 0;"/>
        </HBox>

    </VBox>

</StackPane>

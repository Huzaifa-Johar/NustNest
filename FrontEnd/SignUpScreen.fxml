<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="SignUpController"
        prefWidth="500" prefHeight="680"
        style="-fx-background-color: #1a1f2e;">

    <VBox
            alignment="CENTER"
            maxWidth="380" maxHeight="620"
            style="-fx-background-color: #222736;
               -fx-background-radius: 16;
               -fx-border-color: rgba(255,255,255,0.08);
               -fx-border-radius: 16;
               -fx-border-width: 1;">
        <padding><Insets top="36" right="32" bottom="36" left="32"/></padding>

        <HBox alignment="CENTER_LEFT" spacing="14">
            <VBox.margin><Insets bottom="20"/></VBox.margin>
            <StackPane
                    minWidth="52" minHeight="52"
                    maxWidth="52" maxHeight="52"
                    style="-fx-background-color: #2ecc71;
                       -fx-background-radius: 12;">
                <Label text="N"
                       style="-fx-text-fill: white;
                           -fx-font-size: 22px;
                           -fx-font-weight: bold;"/>
            </StackPane>
            <VBox spacing="2">
                <Label text="Nust Nest"
                       style="-fx-text-fill: #f0f0f0;
                           -fx-font-size: 20px;
                           -fx-font-weight: bold;"/>
                <Label text="Register account"
                       style="-fx-text-fill: #2ecc71;
                           -fx-font-size: 13px;
                           -fx-font-weight: 600;"/>
            </VBox>
        </HBox>

        <Region prefHeight="1" maxWidth="Infinity"
                style="-fx-background-color: rgba(255,255,255,0.08);">
            <VBox.margin><Insets bottom="24"/></VBox.margin>
        </Region>

        <Label text="Full Name"
               style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px; -fx-font-weight: 600;">
            <VBox.margin><Insets bottom="8"/></VBox.margin>
        </Label>
        <TextField fx:id="fullNameField"
                   promptText="e.g. Muhammad Huzaifa"
                   maxWidth="Infinity" prefHeight="46"
                   onAction="#handleCreate"
                   style="-fx-background-color: #2a2f40;
                      -fx-text-fill: #f0f0f0;
                      -fx-prompt-text-fill: #555555;
                      -fx-font-size: 13px;
                      -fx-background-radius: 10;
                      -fx-border-color: rgba(255,255,255,0.12);
                      -fx-border-radius: 10;
                      -fx-border-width: 1;
                      -fx-padding: 0 14 0 14;">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </TextField>

        <Label text="Email Address"
               style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px; -fx-font-weight: 600;">
            <VBox.margin><Insets bottom="8"/></VBox.margin>
        </Label>
        <TextField fx:id="emailField"
                   promptText="yourname@seecs.edu.pk"
                   maxWidth="Infinity" prefHeight="46"
                   onAction="#handleCreate"
                   style="-fx-background-color: #2a2f40;
                      -fx-text-fill: #f0f0f0;
                      -fx-prompt-text-fill: #555555;
                      -fx-font-size: 13px;
                      -fx-background-radius: 10;
                      -fx-border-color: rgba(255,255,255,0.12);
                      -fx-border-radius: 10;
                      -fx-border-width: 1;
                      -fx-padding: 0 14 0 14;">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </TextField>

        <Label text="Password"
               style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px; -fx-font-weight: 600;">
            <VBox.margin><Insets bottom="8"/></VBox.margin>
        </Label>
        <PasswordField fx:id="passwordField"
                       promptText="Create a password"
                       maxWidth="Infinity" prefHeight="46"
                       onAction="#handleCreate"
                       style="-fx-background-color: #2a2f40;
                          -fx-text-fill: #f0f0f0;
                          -fx-prompt-text-fill: #555555;
                          -fx-font-size: 13px;
                          -fx-background-radius: 10;
                          -fx-border-color: rgba(255,255,255,0.12);
                          -fx-border-radius: 10;
                          -fx-border-width: 1;
                          -fx-padding: 0 14 0 14;">
            <VBox.margin><Insets bottom="10"/></VBox.margin>
        </PasswordField>

        <Label fx:id="errorLabel" text=""
               maxWidth="Infinity" minHeight="18"
               style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;">
            <VBox.margin><Insets bottom="14"/></VBox.margin>
        </Label>

        <Button fx:id="createButton"
                text="Register"
                maxWidth="Infinity" prefHeight="46"
                onAction="#handleCreate"
                style="-fx-background-color: #2ecc71;
                   -fx-text-fill: #0d1117;
                   -fx-font-size: 14px;
                   -fx-font-weight: bold;
                   -fx-background-radius: 10;
                   -fx-border-width: 0;
                   -fx-cursor: hand;">
            <VBox.margin><Insets bottom="10"/></VBox.margin>
        </Button>

        <Button text="Back to Login"
                maxWidth="Infinity" prefHeight="42"
                onAction="#handleBackToLogin"
                style="-fx-background-color: transparent;
                   -fx-text-fill: #888888;
                   -fx-font-size: 13px;
                   -fx-border-color: rgba(255,255,255,0.12);
                   -fx-border-radius: 10;
                   -fx-border-width: 1;
                   -fx-background-radius: 10;
                   -fx-cursor: hand;"/>
    </VBox>

    <VBox alignment="BOTTOM_CENTER" mouseTransparent="true">
        <padding><Insets bottom="20"/></padding>
        <Label text="School of Electrical Engineering and Computer Science"
               style="-fx-text-fill: #444444; -fx-font-size: 11px;"/>
        <Label text="National University of Science and Technology"
               style="-fx-text-fill: #444444; -fx-font-size: 11px;"/>
    </VBox>

</StackPane>

